# =============================================================================
# Етап 1: build — компіляція TypeScript у JavaScript
# =============================================================================
FROM node:lts-alpine AS build

WORKDIR /app

# Спочатку копіюємо лише package.json для кешування шару з залежностями.
# Якщо код змінився але залежності ні — Docker не перевстановлюватиме npm пакети.
COPY package*.json ./
RUN npm ci

# Копіюємо весь код і компілюємо
COPY . .
RUN npm run build

# =============================================================================
# Етап 2: production — мінімальний образ без інструментів збірки
# =============================================================================
FROM node:lts-alpine AS production

WORKDIR /app

# Встановлюємо ТІЛЬКИ production-залежності (без devDependencies)
COPY package*.json ./
RUN npm ci --omit=dev

# Копіюємо скомпільований dist з етапу build
# Інструменти збірки (typescript, @nestjs/cli тощо) не потрапляють у фінальний образ
COPY --from=build /app/dist ./dist

# Інформативна декларація порту
EXPOSE 3000

# Запускаємо скомпільований застосунок
CMD ["node", "dist/main.js"]
